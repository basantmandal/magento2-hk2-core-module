{
  "name": "hk2/core",
  "description": "HK2 Core module - The foundational base module for all Magento 2 HK2 extensions.",
  "type": "magento2-module",
  "require": {
    "php": "^8.1 || ^8.2 || ^8.3 ||  ^8.4",
    "magento/framework": "^103.0.0"
  },
  "license": [
    "OSL-3.0"
  ],
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "HK2\\Core\\": ""
    }
  },
  "archive": {
    "exclude": [
      "/.github",
      "/.gitignore",
      "/.releaserc.json",
      "/build",
      "/composer.lock",
      "/node_modules",
      "/package-lock.json",
      "/package.json",
      "/phpcs.xml",
      "/tests"
    ]
  },
  "authors": [
    {
      "name": "Basant Mandal",
      "email": "support@basantmandal.in",
      "homepage": "https://www.basantmandal.in"
    }
  ],
  "support": {
    "email": "support@basantmandal.in"
  },
  "keywords": [
    "magento2",
    "magento-module",
    "hk2",
    "core"
  ]
}
